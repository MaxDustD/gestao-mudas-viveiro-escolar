@page "/especies"
@inject ViveiroApplicationService Service
@using ViveiroEscolar.Library.Domain.Exceptions

<div class="page-header-actions">
  <h2>Espécies</h2>
</div>

<div class="grid">
  <div class="box">
    <h3>Lista de Espécies</h3>
    <table class="table">
      <thead>
        <tr><th>Nome Comum</th><th>Nome Científico</th><th>Id</th></tr>
      </thead>
      <tbody>
        @foreach (var e in especies)
        {
          <tr>
            <td>@e.NomeComum</td>
            <td>@e.NomeCientifico</td>
            <td class="mono">@e.Id</td>
          </tr>
        }
      </tbody>
    </table>
  </div>

  <div class="box">
    <h3>Cadastrar Espécie</h3>
    @if (!string.IsNullOrEmpty(error)) { <div class="error">@error</div> }
    @if (!string.IsNullOrEmpty(success)) { <div class="success">@success</div> }
    <div class="form-row">
      <label>Nome científico</label>
      <input @bind="nomeCientifico" />
    </div>
    <div class="form-row">
      <label>Nome comum</label>
      <input @bind="nomeComum" />
    </div>
    <div class="form-row">
      <label>Observações</label>
      <input @bind="observacoes" />
    </div>
    <div class="form-actions">
      <button class="btn" @onclick="Adicionar">Adicionar</button>
    </div>
  </div>
</div>

@code {
  List<Especie> especies = new();
  string nomeCientifico = string.Empty;
  string nomeComum = string.Empty;
  string? observacoes = null;
  string error = string.Empty;
  string success = string.Empty;

  protected override void OnInitialized()
  {
    Load();
  }

  void Load()
  {
    especies = Service.ListarEspecies().ToList();
  }

  void Adicionar()
  {
    try
    {
      Service.AdicionarEspecie(new Especie(Guid.NewGuid(), nomeCientifico, nomeComum, string.IsNullOrWhiteSpace(observacoes) ? null : observacoes));
      nomeCientifico = nomeComum = string.Empty;
      observacoes = null;
      error = string.Empty;
      success = "Espécie cadastrada com sucesso.";
      Load();
    }
    catch (DomainException ex)
    {
      error = ex.Message;
      success = string.Empty;
    }
  }
}
